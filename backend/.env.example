# SmartShield AI – Environment Variables
# Copy this file to .env and fill in values before running

# Scoring thresholds (0.0 – 1.0)
WARN_THRESHOLD=0.40
BLUR_THRESHOLD=0.60
BLOCK_THRESHOLD=0.80

# Session TTL in seconds (default: 30 minutes)
SESSION_TTL_SECONDS=1800

# Text model (HuggingFace model ID)
TEXT_MODEL_ID=unitary/toxic-bert

# Image model (HuggingFace model ID)
IMAGE_MODEL_ID=Falconsai/nsfw_image_detection

# Set to "true" to use smaller/mock models for faster cold start (useful for demos)
USE_MOCK_MODELS=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
